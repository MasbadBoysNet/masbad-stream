<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <com.pedro.library.view.OpenGlView
        android:id="@+id/glView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/tvWatermark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:text="Mas Badrun Ganteng"
        android:textColor="#33ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:padding="14dp" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="#1a1a2e">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnCamera"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Kamera: Depan" />

            <Button
                android:id="@+id/btnPathCycle"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Stream 1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zoom"
                android:textColor="#ccc"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/zoomSeek"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:max="200"
                android:progress="0"
                android:thumbTint="#4facfe"
                android:progressTint="#4facfe" />

            <TextView
                android:id="@+id/tvZoomLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1x"
                android:textColor="#ccc"
                android:textSize="12sp"
                android:minWidth="32dp"
                android:gravity="end"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnMirror"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Flip: OFF" />

            <Button
                android:id="@+id/btnAudioOnly"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Audio: OFF" />

            <Button
                android:id="@+id/btnRotate"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Potrait" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnLogout"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Keluar" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStream"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Mulai Stream"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:backgroundTint="#4facfe"
            android:textColor="#fff"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Siap"
            android:textColor="#888"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/secretGate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="22dp"
            android:layout_marginHorizontal="32dp"
            android:background="#151525"
            android:backgroundTint="#151525">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile Stream"
                android:textColor="#fff"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masukkan password untuk membuka kamera"
                android:textColor="#aaa"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etSecret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:hint="Password"
                android:textColor="#fff"
                android:textColorHint="#888"
                android:textSize="18sp"
                android:gravity="center"
                android:background="#0f0f18"
                android:padding="14dp" />

            <Button
                android:id="@+id/btnUnlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Buka Kamera"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#4facfe"
                android:textColor="#fff"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/tvSecretError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e74c3c"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:minHeight="18dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
