<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <com.pedro.rtplibrary.view.OpenGlView
        android:id="@+id/glView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controls" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1a1a2e"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Server URL"
            android:text="rtmp://stream.jangrana.my.id:1935/"
            android:textColor="#fff"
            android:textColorHint="#888"
            android:background="#2d2d44"
            android:paddingHorizontal="12dp"
            android:textSize="13sp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/etKey"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:hint="Stream Key"
            android:text="stream1"
            android:textColor="#fff"
            android:textColorHint="#888"
            android:background="#2d2d44"
            android:paddingHorizontal="12dp"
            android:textSize="13sp"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Balik Kamera"
                android:textSize="12sp"
                android:backgroundTint="#2d2d44"
                android:textColor="#fff" />

            <Button
                android:id="@+id/btnAudioOnly"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Audio Only: OFF"
                android:textSize="12sp"
                android:backgroundTint="#2d2d44"
                android:textColor="#fff" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStream"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Mulai Stream"
            android:textSize="15sp"
            android:backgroundTint="#4facfe"
            android:textColor="#fff" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Siap"
            android:textColor="#888"
            android:textSize="12sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:text="Keluar"
            android:textSize="12sp"
            android:backgroundTint="#450000"
            android:textColor="#f87171" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
