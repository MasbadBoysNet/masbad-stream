<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <com.pedro.library.view.OpenGlView
        android:id="@+id/glView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/tapOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/tvWatermark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:text="Mas Badrun Ganteng"
        android:textColor="#33ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:padding="14dp" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="#1a1a2e">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPathCycle"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Stream 1" />

            <Button
                android:id="@+id/btnCamera"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Kamera: Depan" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zoom"
                android:textColor="#ccc"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/zoomSeek"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:max="200"
                android:progress="0"
                android:thumbTint="#4facfe"
                android:progressTint="#4facfe" />

            <TextView
                android:id="@+id/tvZoomLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1x"
                android:textColor="#ccc"
                android:textSize="12sp"
                android:minWidth="32dp"
                android:gravity="end"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnMirror"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:text="Flip: OFF" />

            <Button
                android:id="@+id/btnAudioOnly"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="Video+Audio" />

            <Button
                android:id="@+id/btnRes"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="360p" />

            <Button
                android:id="@+id/btnLogout"
                style="@style/StreamCycleBtn"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="Keluar" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStream"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Mulai Stream"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:backgroundTint="#4facfe"
            android:textColor="#fff"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Siap"
            android:textColor="#888"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>
</FrameLayout>
